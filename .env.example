# DailyBot 环境变量配置
# 复制此文件为 .env 并修改配置

# === 飞书配置 ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_TOKEN=
FEISHU_TARGET_CHAT_ID=
FEISHU_TASKLIST_GUID=
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_OAUTH_HOST=0.0.0.0
FEISHU_OAUTH_PORT=8001

# === 企业微信配置 ===
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_FORM_URL=
WECOM_RPA_ENABLED=true
WECOM_RPA_SPEED=1
WECOM_RPA_BROWSER_TYPE=chrome
WECOM_RPA_AUTO_SUBMIT=false
WECOM_RPA_AUTO_CLEANUP=true

# === AI 模型配置（至少配置一个 API Key） ===
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODELS=

GLM_API_KEY=
GLM_BASE_URL=
GLM_MODELS=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODELS=

KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODELS=

GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODELS=

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODELS=

# === Ollama 本地模型（免费，需本地安装 Ollama） ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODELS=qwen2.5:7b
OLLAMA_PARAMS_TIMEOUT=120

# === Anthropic Claude ===
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODELS=claude-sonnet-4-20250514
ANTHROPIC_PARAMS_TIMEOUT=120

# === GitLab 配置 ===
GITLAB_TOKEN=
GITLAB_BASE_URL=
GITLAB_TARGET_USER=
GITLAB_ENABLED=true
GITLAB_REPOS=
# GITLAB_REPOS 格式：逗号分隔，每个仓库用 路径:分支
# 例如：GITLAB_REPOS=group/project1:main,group/project2:develop

# === GitHub 配置 ===
GITHUB_TOKEN=
GITHUB_ENABLED=false
GITHUB_REPOS=

# === Gitee 配置 ===
GITEE_TOKEN=
GITEE_ENABLED=false
GITEE_REPOS=

# === Redis 配置（OAuth 令牌存储，可选） ===
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# === Web 管理面板 ===
ADMIN_API_KEY=dailybot-admin

# === 调度器配置 ===
SCHEDULER_ENABLED=true
SCHEDULER_DEFAULT_TIME=18:20

# === 日志配置 ===
LOG_LEVEL=INFO
LOG_FILE_LEVEL=DEBUG
